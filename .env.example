# =============================================================================
# Node-RED — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Node-RED stores all persistent data (flows, settings, credentials, npm cache)
# in the /data directory. On Railway, this is backed by a persistent volume.
# =============================================================================

# ---------------------------------------------------------------------------
# Core Configuration
# ---------------------------------------------------------------------------

# Port (default: 1880). Railway sets PORT automatically, but Node-RED
# primarily reads uiPort from /data/settings.js, not the PORT env var.
# PORT=1880

# Flow file to load (default: flows.json)
# FLOWS=flows.json

# ---------------------------------------------------------------------------
# Security & Credentials
# ---------------------------------------------------------------------------

# Custom credential encryption key
# If set, Node-RED uses this key to encrypt credentials stored in flows_cred.json.
# If you lose this key, credentials files become unrecoverable.
# CREDENTIAL_SECRET=my-secret-key

# Enable admin authentication (requires settings.js configuration)
# NODE_RED_USERNAME=admin
# NODE_RED_PASSWORD=password

# ---------------------------------------------------------------------------
# Project Mode
# ---------------------------------------------------------------------------

# Enable projects feature (default: false)
# Requires additional setup in /data/settings.js
# NODE_RED_ENABLE_PROJECTS=false

# ---------------------------------------------------------------------------
# Safe Mode
# ---------------------------------------------------------------------------

# Start Node-RED without running flows (for troubleshooting)
# NODE_RED_ENABLE_SAFE_MODE=false

# ---------------------------------------------------------------------------
# Node Options
# ---------------------------------------------------------------------------

# Additional Node.js runtime options
# NODE_OPTIONS=--max-old-space-size=256
