# Node-RED — Railway Template Environment Variables

# --- Core Configuration ---
# Port (default: 1880). Railway auto-sets PORT; Node-RED uses this via settings.
# PORT=1880

# Flow file to load from /data (default: flows.json)
# FLOWS=flows.json

# --- Security ---
# Encryption key for stored credentials. Set once and never change.
# CREDENTIAL_SECRET=my-secret-key

# --- Features ---
# Enable Git-backed projects (requires settings.js configuration)
# NODE_RED_ENABLE_PROJECTS=false

# Start without running flows (for troubleshooting)
# NODE_RED_ENABLE_SAFE_MODE=false
